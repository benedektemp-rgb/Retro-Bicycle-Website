# Copy this file to .env.local for local development, and set the same
# values in your Vercel project's Environment Variables for production.

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Admin login ---
# Generate the password hash with: node scripts/hash-password.mjs "your-password"
# Note the escaped \$ signs below -- Next.js expands unescaped $VAR references in .env
# files, which would corrupt a bcrypt hash. Use the raw (unescaped) hash in Vercel instead.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=\$2b\$12\$replace-with-generated-hash

# --- Session signing secret ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=replace-with-a-long-random-string
